# Object files
*.o
*.ko
*.obj
*.elf

# Libraries
*.lib
*.a

# Shared objects (inc. Windows DLLs)
*.dll
*.so
*.so.*
*.dylib

# Executables
*.exe
*.out
*.app
*.i*86
*.x86_64
*.hex

# RFC traces
*.trc
*.log

# SAP RFC connection profiles — never commit; may contain credentials,
# system numbers, hostnames, SNC partner names. Use sapnwrfc.ini.example
# (placeholder values only) as the in-tree reference.
sapnwrfc.ini
**/sapnwrfc.ini

# SAP cryptographic / SNC artifacts (PSE files, SAP credential cache,
# secudir contents). Never commit. Operators provide these out-of-band.
*.pse
**/*.pse
**/sec/

# SAP NetWeaver RFC SDK and SAP CommonCryptoLib are proprietary. Users
# install them under their own SAP entitlement; do not commit binaries.
nwrfcsdk/
**/nwrfcsdk/
sapcrypto/
**/sapcrypto/

# Packages
GoRFC/pkg/

# Dependencies
stretchr

# others
.DS_Store
Thumbs.db
*.tmp


